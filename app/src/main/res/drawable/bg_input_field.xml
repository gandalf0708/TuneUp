<?xml version="1.0" encoding="utf-8"?>
    <shape xmlns:android="http://schemas.android.com/apk/res/android">
        <!-- צבע הרקע של השדה - כהה מעט יותר מהכרטיס -->
        <solid android:color="#252525" />

        <!-- עובי וצבע המסגרת -->
        <stroke
            android:width="1dp"
            android:color="#333333" />

        <!-- רדיוס הפינות (כדי שיהיה מעוגל ומודרני) -->
        <corners android:radius="12dp" />

        <!-- ריווח פנימי לטקסט -->
        <padding
            android:left="12dp"
            android:right="12dp"
            android:top="8dp"
            android:bottom="8dp" />
    </shape>
