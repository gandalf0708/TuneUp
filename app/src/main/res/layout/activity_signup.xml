<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_dark"
    android:fillViewport="true"
    tools:context=".SignupActivity"> <!-- התיקון נמצא כאן -->

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="24dp">

        <!-- כותרת הרשמה -->
        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="הירשם ל-Tuneup"
            android:textColor="@color/white"
            android:textSize="32sp"
            android:textStyle="bold"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            android:layout_marginBottom="8dp"/>

        <!-- כותרת משנה -->
        <TextView
            android:id="@+id/tvSubtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="בוא נתחיל ליצור מוזיקה"
            android:textColor="@color/text_hint"
            android:textSize="16sp"
            app:layout_constraintTop_toBottomOf="@+id/tvTitle"
            app:layout_constraintStart_toStartOf="parent"
            android:layout_marginBottom="40dp"/>

        <!-- שדה שם מלא -->
        <LinearLayout
            android:id="@+id/etNameContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_glass_card"
            android:orientation="horizontal"
            android:padding="16dp"
            android:gravity="center_vertical"
            app:layout_constraintTop_toBottomOf="@+id/tvSubtitle"
            android:layout_marginTop="32dp">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@android:drawable/ic_menu_edit"
                app:tint="@color/text_hint"
                android:contentDescription="אייקון שם"
                android:layout_marginEnd="12dp"/>

            <EditText
                android:id="@+id/etFullName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@null"
                android:hint="שם מלא"
                android:textColor="@color/white"
                android:textColorHint="@color/text_hint"
                android:inputType="textPersonName"
                android:minHeight="48dp" />
        </LinearLayout>

        <!-- שדה אימייל -->
        <LinearLayout
            android:id="@+id/etEmailContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_glass_card"
            android:orientation="horizontal"
            android:padding="16dp"
            android:gravity="center_vertical"
            app:layout_constraintTop_toBottomOf="@+id/etNameContainer"
            android:layout_marginTop="16dp">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@android:drawable/ic_dialog_email"
                app:tint="@color/text_hint"
                android:contentDescription="אייקון אימייל"
                android:layout_marginEnd="12dp"/>

            <EditText
                android:id="@+id/etEmailSignup"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@null"
                android:hint="אימייל"
                android:textColor="@color/white"
                android:textColorHint="@color/text_hint"
                android:inputType="textEmailAddress"
                android:minHeight="48dp" />
        </LinearLayout>

        <!-- שדה סיסמה -->
        <LinearLayout
            android:id="@+id/etPasswordContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_glass_card"
            android:orientation="horizontal"
            android:padding="16dp"
            android:gravity="center_vertical"
            app:layout_constraintTop_toBottomOf="@+id/etEmailContainer"
            android:layout_marginTop="16dp">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@android:drawable/ic_lock_idle_lock"
                app:tint="@color/text_hint"
                android:contentDescription="אייקון סיסמה"
                android:layout_marginEnd="12dp"/>

            <EditText
                android:id="@+id/etPasswordSignup"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@null"
                android:hint="סיסמה"
                android:textColor="@color/white"
                android:textColorHint="@color/text_hint"
                android:inputType="textPassword"
                android:minHeight="48dp" />
        </LinearLayout>

        <!-- שדה אישור סיסמה -->
        <LinearLayout
            android:id="@+id/etConfirmPasswordContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_glass_card"
            android:orientation="horizontal"
            android:padding="16dp"
            android:gravity="center_vertical"
            app:layout_constraintTop_toBottomOf="@+id/etPasswordContainer"
            android:layout_marginTop="16dp">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@android:drawable/ic_lock_idle_lock"
                app:tint="@color/text_hint"
                android:contentDescription="אייקון אישור סיסמה"
                android:layout_marginEnd="12dp"/>

            <EditText
                android:id="@+id/etConfirmPassword"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@null"
                android:hint="אישור סיסמה"
                android:textColor="@color/white"
                android:textColorHint="@color/text_hint"
                android:inputType="textPassword"
                android:minHeight="48dp" />
        </LinearLayout>

        <!-- כפתור הרשמה -->
        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnSignup"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="הירשם"
            android:textColor="@color/white"
            android:textStyle="bold"
            android:background="@drawable/bg_glass_card"
            android:backgroundTint="@color/neon_purple"
            android:layout_marginTop="32dp"
            android:padding="16dp"
            app:layout_constraintTop_toBottomOf="@+id/etConfirmPasswordContainer" />

        <!-- מעבר למסך התחברות -->
        <TextView
            android:id="@+id/tvLoginPrompt"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="כבר יש לך משתמש? התחבר"
            android:textColor="@color/text_hint"
            android:textSize="14sp"
            android:layout_marginTop="24dp"
            app:layout_constraintTop_toBottomOf="@+id/btnSignup"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

    </androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView>
